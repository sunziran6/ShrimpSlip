# ==========================================
# 本地开发环境配置模板
# 复制此文件为 application-dev.yml 并填入真实值
# application-dev.yml 已被 .gitignore 忽略
# ==========================================

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/shrimpslip?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
    username: root
    password: 你的MySQL密码
  data:
    redis:
      host: localhost
      port: 6379

shrimp:
  jwt:
    secret: 你的JWT密钥（随意填写一段长字符串）
